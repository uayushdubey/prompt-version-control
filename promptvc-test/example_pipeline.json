{
  "name": "review_pipeline",
  "description": "Extract issues, fix code, then explain the fix",
  "steps": [
    {
      "id": "extract",
      "prompt": "extract_issues",
      "version": "v1",
      "vars": {
        "code": "{{ input.code }}"
      }
    },
    {
      "id": "fix",
      "prompt": "fix_code",
      "version": "v1",
      "vars": {
        "issues": "{{ steps.extract.output }}",
        "code":   "{{ input.code }}"
      }
    },
    {
      "id": "explain",
      "prompt": "explain_fix",
      "version": "v1",
      "vars": {
        "before": "{{ input.code }}",
        "after":  "{{ steps.fix.output }}"
      }
    }
  ]
}
